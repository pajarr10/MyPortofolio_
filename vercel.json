{
  "version": 2,
  "builds": [
    { "src": "analytics/server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "404.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "analytics-tracker.js", "use": "@vercel/static" },
    { "src": "bio-link/index.html", "use": "@vercel/static" },

    { "src": "googleda2d21a3857f78a7.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "analytics/server.js" },
    { "src": "/admin.html", "dest": "analytics/server.js" },
    { "src": "/bio-link", "dest": "/bio-link/index.html" },
    { "src": "/bio-link/(.*)", "dest": "/bio-link/$1" },
    { "src": "/(.*)", "dest": "/$1" },

    { "handle": "error" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ]
}